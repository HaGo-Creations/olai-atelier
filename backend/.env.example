# backend/.env.example
#
# Copy this file to backend/.env and fill in your values.
# backend/.env is gitignored — never commit real keys.
#
# ── DEPLOYMENT MODE ─────────────────────────────────────────────────────────
#
#  Cloud (Hugging Face Space):
#    Set GOOGLE_API_KEY. Leave OLLAMA_* as-is (Ollama won't be reachable).
#
#  Local (Ollama on your machine):
#    Leave GOOGLE_API_KEY empty. Set OLLAMA_MODEL to match `ollama list`.
#
#  Both (hybrid): Set all of the below. Backend will try cloud first (auto mode),
#    fall back to local when the frontend selects "Local" model mode.

# ── Google AI Studio (cloud Gemma 4) ────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Model used for cloud generation (do not change unless Google updates the ID)
CLOUD_MODEL=gemma-4-26b-a4b-it

# ── Ollama (local Gemma 4) ───────────────────────────────────────────────────
# URL of your Ollama instance.
#   Native install on host:  http://localhost:11434
#   Docker Compose (backend in container): http://ollama:11434  (set by compose)
OLLAMA_URL=http://localhost:11434

# Model name — must match exactly what appears in `ollama list`.
# Common Gemma 4 names in Ollama:
#   gemma4:4b      (4B instruction-tuned, ~3 GB, fast on CPU)
#   gemma4:12b     (12B, needs ~8 GB RAM / VRAM)
#   gemma4:27b     (27B, needs ~16 GB VRAM)
OLLAMA_MODEL=gemma4:4b

# Model used for audio transcription (E2B has native audio support).
# If you only have one Gemma model, set this to the same as OLLAMA_MODEL.
OLLAMA_MODEL_AUDIO=gemma4:4b

# ── Export ───────────────────────────────────────────────────────────────────
# Where exported DOCX/PDF files are saved. /tmp is fine for demos.
EXPORT_DIR=/tmp/gemma_exports
